# Service
APP_NAME=agentic-ai-microservice-api
APP_VERSION=0.1.0
API_HOST=127.0.0.1
API_PORT=8000
ALLOWED_ORIGINS=*
LOG_LEVEL=INFO

# LLM Provider (Gemini via OpenAI-compatible endpoint)
LLM_PROVIDER=openai_compatible
GEMINI_API_KEY=your_gemini_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_DEFAULT_MODEL=models/gemini-2.5-flash
LLM_DEFAULT_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30

# Runtime Guardrails
DEFAULT_MAX_STEPS=8
DEFAULT_MAX_TOOL_CALLS=12
DEFAULT_MAX_RUNTIME_SECONDS=45
TOOL_TIMEOUT_SECONDS=6
REPEATED_TOOL_CALL_THRESHOLD=2
ENABLE_STREAM_ENDPOINT=true
